# Example environment variables.
# Copy this file to `.env` and fill with your real secrets locally.
# DO NOT commit the `.env` file.

# MongoDB connection string (get from MongoDB Atlas)
MONGODB_URI="<YOUR_MONGODB_URI_HERE>"

# MongoDB database name (optional)
MONGODB_DB="smgs"

# JWT secret for signing tokens (use a long random string)
JWT_SECRET="<YOUR_JWT_SECRET_HERE>"

# CORS origin for deployed frontend (for production)
# Leave empty to allow all origins, or set to your frontend URL
# CORS_ORIGIN=https://your-frontend-url.vercel.app

# Server port (optional) - typically not needed on hosting platforms
# PORT=5000

# Environment (development|production)
NODE_ENV=development
